# Variables d'environnement — Mon Suivi Sportif
# Copier ce fichier en .env et remplir les valeurs

# Port d'écoute du serveur (défaut: 3001)
PORT=3001

# Token d'accès partagé entre le client et le serveur
# Changer obligatoirement avant de déployer
TOKEN=changeme

# Clé API Anthropic (pour le proxy /api/ai — assistant IA)
# Obtenir sur https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Base de données PostgreSQL
DB_HOST=192.168.1.6
DB_NAME=suivi_sportif
DB_USER=suivi
DB_PASSWORD=
DB_PORT=5432
